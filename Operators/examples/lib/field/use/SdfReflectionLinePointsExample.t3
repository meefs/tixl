    {
      "Id": "63dbd215-2d00-4e3e-b61c-35a7e5bfa1b9"/*CustomSDF*/,
      "SymbolId": "637d00e4-ab63-4fe3-8e63-1e206c728841",
      "InputValues": [
        {
          "Id": "3c366d34-c398-410e-972b-d8cc2baffddb"/*A*/,
          "Type": "System.Single",
          "Value": 0.223
        },
        {
          "Id": "56e5d5ec-ec59-4ea0-85c1-1eca3dcb5790"/*C*/,
          "Type": "System.Single",
          "Value": -0.038
        },
        {
          "Id": "874ae9c8-5835-4d0c-9bef-253ac75d19b2"/*B*/,
          "Type": "System.Single",
          "Value": 1.14
        },
        {
          "Id": "bde89b93-224c-4a3f-85ab-d85b0401c02a"/*DistanceFunction*/,
          "Type": "System.String",
          "Value": "// From https://jbaker.graphics/writings/DEC.html\nfloat4 p2 = float4(p.yxz, 1);\nfor(int i = 0; i < 4; i++){\n  p2.xyz = mod(p2.xyz - 1, 2 + C) - 1; // C: 0.0\n  p2*=(B/dot(p2.xyz, p2.xyz));  // B: 1.2\n}\np2/=p2.w;\nreturn abs(p2.x) * A;  // A: 0.25"
        }
      ],
      "Outputs": []
    },
